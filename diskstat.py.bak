#!/usr/bin/env python3
"""Disk usage analyzer (WinDirStat-like). Scans a directory, then produces an HTML treemap + CSV report."""

import os, sys, time, datetime, json, shutil, csv, pathlib, webbrowser, re

DEFAULT_TARGET = "/mnt/c/"
WSL_DRIVE_RE = re.compile(r"^([A-Za-z]):[\\/].*")


def normalize_path(p: str) -> str:
    """Accept either Windows (C:\\...) or WSL/mount ( /mnt/c/...) paths."""
    p = os.path.expanduser(p)
    if WSL_DRIVE_RE.match(p):
        drive = p[0].lower()
        rest = p[2:].replace("\\", "/")
        if not rest.startswith("/"):
            rest = "/" + rest
        p = "/mnt/" + drive + rest
    return p


EXT_COLORS = {
    "folder": "#1f77b4",
    "unknown": "#cccccc",
    "zip": "#ff7f0e",
    "image": "#9467bd",
    "video": "#d62728",
    "audio": "#8c564b",
    "doc": "#2ca02c",
    "code": "#17becf",
    "exe": "#e377c2",
    "font": "#bcbd22",
    "data": "#7f7f7f",
    "system": "#aec7e8",
}

EXT_MAP = {
    "zip": {".zip", ".7z", ".rar", ".tar", ".gz", ".bz2", ".xz", ".tgz", ".lz", ".zst"},
    "image": {".jpg", ".jpeg", ".png", ".gif", ".bmp", ".tif", ".tiff", ".webp", ".ico", ".avif"},
    "video": {".mp4", ".avi", ".mkv", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".m2ts", ".vob"},
    "audio": {".mp3", ".wav", ".aac", ".flac", ".m4a", ".wma", ".ogg", ".opus", ".aiff", ".alac"},
    "doc": {".pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".odt", ".ods", ".odp", ".txt", ".rtf", ".csv", ".md", ".pages", ".key", ".numbers"},
    "code": {".py", ".js", ".ts", ".java", ".c", ".cpp", ".h", ".cs", ".go", ".rs", ".php", ".rb", ".swift", ".kt", ".scala", ".html", ".css", ".scss", ".less", ".sql", ".sh", ".bat", ".ps1", ".psm1", ".vue", ".jsx", ".tsx", ".json", ".yaml", ".yml", ".toml", ".xml", ".ini", ".cfg", ".conf"},
    "exe": {".exe", ".dll", ".so", ".dylib", ".bin", ".msi", ".app", ".apk", ".ipa"},
    "font": {".ttf", ".otf", ".woff", ".woff2", ".eot", ".fnt", ".fon"},
    "data": {".db", ".sqlite", ".sqlite3", ".mdb", ".accdb", ".dat", ".log", ".iso", ".img", ".bak", ".tmp", ".cache"},
    "system": {".sys", ".lnk", ".url", ".reg", ".cab"},
}


def ext_category(name, is_dir=False):
    if is_dir:
        return "folder"
    ext = pathlib.Path(name).suffix.lower()
    for cat, exts in EXT_MAP.items():
        if ext in exts:
            return cat
    return "unknown"


def format_bytes(b):
    if not b:
        return "0.0 B"
    units = ["B", "KB", "MB", "GB", "TB", "PB"]
    i = int(min(len(units) - 1, (b.bit_length() - 1) // 10))
    v = b / (1024 ** i)
    return f"{v:.1f} {units[i]}"


def scan(path: str):
    path = normalize_path(path)
    root_name = os.path.splitdrive(path)[1].rstrip("\\/") or "\\"
    tree = {"name": root_name, "path": path, "size": 0, "category": "folder"}
    t0 = time.time()
    scanned_files = 0
    scanned_dirs = 0
    skipped = 0

    def _walk(directory: str, node: dict):
        nonlocal scanned_files, scanned_dirs, skipped
        if not os.path.isdir(directory):
            return 0
        try:
            entries = sorted(os.scandir(directory), key=lambda e: e.name)
        except (OSError, PermissionError):
            skipped += 1
            return 0
        size = 0
        for entry in entries:
            try:
                if entry.is_dir(follow_symlinks=False):
                    scanned_dirs += 1
                    child = {
                        "name": entry.name,
                        "path": os.path.join(directory, entry.name),
                        "size": 0,
                        "category": "folder",
                        "children": [],
                    }
                    node.setdefault("children", []).append(child)
                    size += _walk(entry.path, child)
                elif entry.is_file(follow_symlinks=False):
                    try:
                        sz = entry.stat(follow_symlinks=False).st_size
                    except OSError:
                        sz = 0
                    scanned_files += 1
                    node.setdefault("children", []).append(
                        {
                            "name": entry.name,
                            "path": os.path.join(directory, entry.name),
                            "size": sz,
                            "category": ext_category(entry.name, is_dir=False),
                        }
                    )
                    size += sz
            except (OSError, PermissionError):
                skipped += 1
                continue
        node["size"] = size
        return size

    _walk(path, tree)
    return tree, {
        "files": scanned_files,
        "dirs": scanned_dirs,
        "skipped": skipped,
        "elapsed_s": round(time.time() - t0, 3),
        "root": path,
    }


def build_flat(tree, max_nodes: int = 5000):
    out = [
        {
            "name": tree.get("name", "ROOT"),
            "path": tree.get("path", ""),
            "size": tree.get("size", 0),
            "category": "folder",
            "parent": None,
        }
    ]
    remaining = max_nodes - 1
    if remaining <= 0:
        return out

    def add_children(node: dict, parent_name: str):
        nonlocal remaining
        if remaining <= 0:
            return
        children = node.get("children", [])
        children.sort(key=lambda x: x.get("size", 0), reverse=True)
        keep = min(len(children), remaining)
        for child in children[:keep]:
            remaining -= 1
            cat = child.get("category", "folder" if "children" in child else "unknown")
            out.append(
                {
                    "name": child.get("name", "?"),
                    "path": child.get("path", ""),
                    "size": child.get("size", 0),
                    "parent": parent_name,
                    "category": cat,
                }
            )
            if cat == "folder" and child.get("children"):
                add_children(child, child.get("name"))

    add_children(tree, tree.get("name", "ROOT"))
    return out


def render_html(tree_data, flat, target, output_html, csv_path):
    def color_for(cat, name=""):
        return EXT_COLORS.get(cat, EXT_COLORS["unknown"])

    js_flat = json.dumps(flat, ensure_ascii=False)
    js_colors = json.dumps(EXT_COLORS, ensure_ascii=False)

    html = f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Disk Usage - {tree_data.get('name', 'ROOT')}</title>
<style>
:root {{
  --bg:#0b0d10; --panel:#111418; --panel2:#1b1f26; --text:#e6e8eb; --muted:#7a8595; --line:#252b33; --accent:#0ea5e9;
}}
* {{ box-sizing: border-box; }}
html,body {{ height:100%; margin:0; background:var(--bg); color:var(--text); font:14px/1.4 -apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif; }}
header {{ position:sticky; top:0; z-index:10; background:#0d1117ee; backdrop-filter:saturate(140%) blur(6px); border-bottom:1px solid var(--line); padding:14px 18px 10px; }}
.wrap {{ display:grid; grid-template-columns: 1fr 400px; gap:0; height: calc(100vh - 58px); }}
#viz {{ overflow:hidden; }}
aside {{ border-left:1px solid var(--line); background:var(--panel); padding:14px; overflow:auto; }}
.h1 {{ margin:0 0 6px; font-size:16px; font-weight:600; letter-spacing:.2px; }}
.info {{ color:var(--muted); font-size:12px; }}
.legend {{ display:flex; flex-wrap:wrap; gap:6px 12px; margin-top:10px; }}
.chip {{ display:inline-flex; align-items:center; gap:7px; background:var(--panel2); border:1px solid #222833; padding:3px 8px; border-radius:999px; font-size:11px; color:#cfd6e0; }}
.dot {{ width:10px; height:10px; border-radius:50%; display:inline-block; border:1px solid #2a3140; }}
path {{ cursor:pointer; }}
input[type=text] {{ width:100%; padding:7px 8px; border-radius:6px; border:1px solid #2c333d; background:#0c1015; color:#e6e8eb; outline:none; }}
a {{ color:#bde0fe; text-decoration:none; }}
.table {{ width:100%; border-collapse:collapse; margin-top:12px; }}
.table th {{ text-align:left; color:#9aa5b2; font-weight:500; font-size:11px; padding:6px 4px; }}
.table td {{ padding:6px 4px; border-top:1px solid #1d222b; font-size:12px; color:#cdd4de; }}
.table tr:hover td {{ background:#0f1318; }}
.badge {{ display:inline-block; padding:1px 7px; border-radius:999px; background:#1b1f26; border:1px solid #2a3140; font-size:10px; color:#9aa5b2; }}
.tooltip {{ position:fixed; background:#0f1418ee; border:1px solid #2a3140; padding:7px 9px; border-radius:7px; font-size:12px; pointer-events:none; opacity:0; transition:opacity .08s; max-width:440px; }}
.small {{ color:#7a8595; font-size:11px; }}
</style>
</head>
<body>
<header>
  <div class="h1">Disk Usage - {tree_data.get('name', 'ROOT')}</div>
  <div class="info">Rectangles sized by size. Click a region to zoom deeper. Table shows top items for selection.</div>
  <div class="legend" id="legend"></div>
  <div style="margin-top:10px;">
    <input type="text" id="filter" placeholder="Filter name/path…" autocomplete="off"/>
    <div class="small">Table is live-filtered. Click a row to open location.</div>
  </div>
</header>
<div class="wrap">
  <div id="viz"></div>
  <aside>
    <div class="info">Current: <span id="breadcrumb">/</span></div>
    <div class="info" id="selection" style="margin-top:8px"></div>
    <div id="actions" style="margin-top:10px; display:flex; gap:8px;"></div>
    <table class="table">
      <thead><tr><th>Name</th><th>Size</th><th>Type</th></tr></thead>
      <tbody id="tbl"></tbody>
    </table>
  </aside>
</div>
<div class="tooltip" id="tooltip"></div>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
const flat = {js_flat};
const catColor = (cat) => ({js_colors})[cat] || '#cccccc';
const fmtBytes = (n) => {{
  if (!n && n !== 0) return '...';
  if (n === 0) return '0 B';
  const u = ['B','KB','MB','GB','TB'];
  const i = Math.min(u.length-1, Math.max(0, Math.floor(Math.log(n)/Math.log(1024))));
  return (n/1024**i).toFixed(1) + ' ' + u[i];
}};
const escapeHtml = (s) => String(s||'').replace(/[&<>']/g, c => ({{'&':'&amp;','<':'&lt;','>':'&gt;','\\'':'&apos;'}}[c]));

function legend() {{
  const cats = Object.keys({js_colors});
  const el = document.getElementById('legend');
  el.innerHTML = '';
  for (const c of cats) {{
    const s = document.createElement('span');
    s.className = 'chip';
    s.innerHTML = `<span class="dot" style="background:${{catColor(c)}}"></span>${{c==='folder'?'folder':c==='unknown'?'unknown':c}}`;
    el.appendChild(s);
  }}
}}
legend();

const rootName = '{tree_data.get('name', 'ROOT')}';
const rootNode = flat.find(n => n.name === rootName) || flat[0];
const childrenOf = (parentName) => flat.filter(n => n.parent === parentName);
const buildChildren = (nodeName) => {{
  const kids = childrenOf(nodeName);
  return {{ name: nodeName, path: (flat.find(n=>n.name===nodeName)||{{}}).path||'', size: 0, category: 'folder', children: kids }};
}};

function render(nodeName) {{
  const node = buildChildren(nodeName);
  node.children.forEach(c => c.children = []);
  const total = node.children.reduce((a,b)=>a+b.size,0) || 1;
  document.getElementById('breadcrumb').textContent = node.path || nodeName;
  document.getElementById('selection').textContent = `${{node.children.length}} items | ${{fmtBytes(total)}}`;

  const width = document.getElementById('viz').clientWidth || 900;
  const height = document.getElementById('viz').clientHeight || 700;
  const svg = d3.select('#viz').html('').append('svg').attr('width', width).attr('height', height);
  const tooltip = document.getElementById('tooltip');
  const root = d3.hierarchy(node).sum(d => d.size || 0).sort((a,b) => b.value - a.value);
  d3.treemap().size([width, height]).padding(2).tile(d3.treemapSquarify)(root);
  const leaves = root.leaves();
  const g = svg.selectAll('g').data(leaves).join('g').attr('transform', d => `translate(${{d.x0}},${{d.y0}})`);
  g.append('rect')
    .attr('width', d => Math.max(0, d.x1 - d.x0))
    .attr('height', d => Math.max(0, d.y1 - d.y0))
    .attr('fill', d => {{
      const cat = d.data.category || 'unknown';
      return catColor(cat==='folder' && d.data.path ? 'folder' : cat);
    }})
    .attr('stroke', '#0b0d10')
    .attr('stroke-width', 1)
    .on('mousemove', (e, d) => {{
      tooltip.style.opacity = 1;
      tooltip.style.left = (e.clientX + 12) + 'px';
      tooltip.style.top = (e.clientY + 12) + 'px';
      tooltip.innerHTML = `<b>${{escapeHtml(d.data.name)}}</b><br/>${{fmtBytes(d.data.size)}}<br/><span style="color:#8b97a6">${{escapeHtml(d.data.path||'')}}</span>`;
    }})
    .on('mouseleave', () => tooltip.style.opacity = 0)
    .on('click', (e, d) => {{
      e.stopPropagation();
      const c = d.data;
      if (c.category === 'folder' && c.path) drill(c.name, c.path);
      else openPath(c.path);
    }});
  g.append('text').attr('x', 4).attr('y', 14).attr('fill', '#eaf0f6').attr('font-size', 11)
    .text(d => {{
      const w = d.x1 - d.x0;
      if (w < 36) return '';
      const t = d.data.name;
      const max = Math.max(3, Math.floor((w - 4) / 7.2));
      return t.length > max ? t.slice(0, max) + '…' : t;
    }});
  updateTable(node);
}}

function drill(name, path) {{ current = name; render(); }}
function updateTable(node) {{
  let rows = node.children.slice().sort((a,b)=>b.size-a.size);
  const q = document.getElementById('filter').value.trim().toLowerCase();
  if (q) rows = rows.filter(r => (r.name + ' ' + (r.path||'')).toLowerCase().includes(q));
  rows = rows.slice(0, 200);
  const tb = document.getElementById('tbl');
  tb.innerHTML = '';
  for (const r of rows) {{
    const tr = document.createElement('tr');
    tr.innerHTML = `<td><a href="#">${{escapeHtml(r.name)}}</a><div class="small">${{escapeHtml((r.path||''))}}</div></td><td>${{fmtBytes(r.size)}}</td><td><span class="badge">${{escapeHtml(r.category)}}</span></td>`;
    tr.addEventListener('click', () => openPath(r.path || ''));
    tb.appendChild(tr);
  }}
}}
function openPath(p) {{ if (!p) return; if (navigator.clipboard) navigator.clipboard.writeText(p); alert('Path copied to clipboard:\\n' + p + '\\n\\nIn a real Windows build, we would open Explorer here.'); }}
document.getElementById('filter').addEventListener('input', () => render());
window.addEventListener('resize', () => render());
render();
</script>
</body>
</html>
"""
    with open(output_html, "w", encoding="utf-8") as f:
        f.write(html)

    with open(csv_path, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow(["name", "path", "size_bytes", "size_human", "category", "parent"])
        for row in flat:
            writer.writerow(
                [
                    row.get("name", ""),
                    row.get("path", ""),
                    row.get("size", 0),
                    format_bytes(row.get("size", 0)),
                    row.get("category", "unknown"),
                    row.get("parent", ""),
                ]
            )


def main():
    import argparse

    ap = argparse.ArgumentParser(description="Disk usage analyzer (WinDirStat-like) for Windows/WSL")
    ap.add_argument("path", nargs="?", default="/mnt/c/", help="Path to scan (default: /mnt/c/)")
    ap.add_argument("-o", "--out", default=None, help="Output directory")
    ap.add_argument("--open", action="store_true", help="Open HTML report after generation")
    ap.add_argument("-m", "--max-nodes", type=int, default=5000, help="Max nodes to include in visualization")
    args = ap.parse_args()

    target = args.path
    out_dir = args.out or os.path.join(os.getcwd(), "diskstat", datetime.datetime.now().strftime("%Y%m%d_%H%M%S"))
    os.makedirs(out_dir, exist_ok=True)
    html_out = os.path.join(out_dir, "report.html")
    csv_out = os.path.join(out_dir, "files.csv")

    print(f"Scanning: {normalize_path(target)}")
    tree, stats = scan(target)
    total = tree.get("size", 0)
    print(
        f"Done: {stats['elapsed_s']}s | {stats['dirs']} dirs, {stats['files']} files, {stats['skipped']} skipped | {format_bytes(total)} total"
    )

    flat = build_flat(tree, max_nodes=int(args.max_nodes))
    render_html(tree, flat, target, html_out, csv_out)
    print(f"HTML : {html_out}")
    print(f"CSV  : {csv_out}")
    if args.open:
        webbrowser.open("file://" + html_out)


if __name__ == "__main__":
    main()
